<Window x:Class="SimpleCalculator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SimpleCalculator"
        mc:Ignorable="d"
        Title="Calculator" 
        Height="700" 
        Width="400" 
        Background="LightPink">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="300"/>
            <!-- Дисплей -->
            <RowDefinition Height="*"/>
            <!-- Кнопки -->
        </Grid.RowDefinitions>

        <!-- Дисплей -->
        <Border Grid.Row="0" Background="White" Margin="10" CornerRadius="10">
            <StackPanel VerticalAlignment="Bottom" Margin="15">
                <TextBlock x:Name="Input" 
                           Text="" 
                           FontSize="40" 
                           Foreground="Gray"
                           HorizontalAlignment="Right"
                           Margin="0,0,0,10"/>
                <TextBlock x:Name="Output" 
                           Text="0" 
                           FontSize="70" 
                           Foreground="Black"
                           HorizontalAlignment="Right"
                           FontWeight="Bold"/>
            </StackPanel>
        </Border>

        <!-- кнопки -->
        <Grid Grid.Row="1" Margin="10">
            <!-- 5 строк, 4 столбца -->
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Row 0: C, ±, ⌫, / -->
            <Button Grid.Row="0" Grid.Column="0" Content="C" FontSize="24" Margin="3" Click="BtnClear_Click" Background="White"/>
            <Button Grid.Row="0" Grid.Column="1" Content="±" FontSize="24" Margin="3" Click="BtnToggleSign_Click" Background="White"/>
            <Button Grid.Row="0" Grid.Column="2" Content="⌫" FontSize="24" Margin="3" Click="BtnBackspace_Click" Background="White"/>
            <Button Grid.Row="0" Grid.Column="3" Content="/" FontSize="24" Margin="3" Click="BtnOperation_Click" Tag="/" Background="White"/>

            <!-- Row 1: 7, 8, 9, * -->
            <Button Grid.Row="1" Grid.Column="0" Content="7" FontSize="24" Margin="3" Click="BtnDigit_Click" Tag="7" Background="LightBlue"/>
            <Button Grid.Row="1" Grid.Column="1" Content="8" FontSize="24" Margin="3" Click="BtnDigit_Click" Tag="8" Background="LightBlue"/>
            <Button Grid.Row="1" Grid.Column="2" Content="9" FontSize="24" Margin="3" Click="BtnDigit_Click" Tag="9" Background="LightBlue"/>
            <Button Grid.Row="1" Grid.Column="3" Content="*" FontSize="24" Margin="3" Click="BtnOperation_Click" Tag="*" Background="White"/>

            <!-- Row 2: 4, 5, 6, - -->
            <Button Grid.Row="2" Grid.Column="0" Content="4" FontSize="24" Margin="3" Click="BtnDigit_Click" Tag="4" Background="LightBlue"/>
            <Button Grid.Row="2" Grid.Column="1" Content="5" FontSize="24" Margin="3" Click="BtnDigit_Click" Tag="5" Background="LightBlue"/>
            <Button Grid.Row="2" Grid.Column="2" Content="6" FontSize="24" Margin="3" Click="BtnDigit_Click" Tag="6" Background="LightBlue"/>
            <Button Grid.Row="2" Grid.Column="3" Content="-" FontSize="24" Margin="3" Click="BtnOperation_Click" Tag="-" Background="White"/>

            <!-- Row 3: 1, 2, 3, + -->
            <Button Grid.Row="3" Grid.Column="0" Content="1" FontSize="24" Margin="3" Click="BtnDigit_Click" Tag="1" Background="LightBlue"/>
            <Button Grid.Row="3" Grid.Column="1" Content="2" FontSize="24" Margin="3" Click="BtnDigit_Click" Tag="2" Background="LightBlue"/>
            <Button Grid.Row="3" Grid.Column="2" Content="3" FontSize="24" Margin="3" Click="BtnDigit_Click" Tag="3" Background="LightBlue"/>
            <Button Grid.Row="3" Grid.Column="3" Content="+" FontSize="24" Margin="3" Click="BtnOperation_Click" Tag="+" Background="White"/>

            <!-- Row 4: 0, ., = -->
            <Button Grid.Row="4" Grid.Column="0" Content="0" FontSize="24" Margin="3" Grid.ColumnSpan="2" Click="BtnDigit_Click" Tag="0" Background="LightBlue"/>
            <Button Grid.Row="4" Grid.Column="2" Content="." FontSize="24" Margin="3" Click="BtnDecimal_Click" Tag="." Background="White"/>
            <Button Grid.Row="4" Grid.Column="3" Content="=" FontSize="24" Margin="3" Click="BtnEquals_Click" Tag="=" Background="White"/>
        </Grid>
    </Grid>
</Window>